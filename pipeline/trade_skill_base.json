  "methodology_note": "worst_positions agrupado por underlying+vencimento (spread completo, nao perna individual). net_total = soma de todas as opcoes abertas e fechadas no mesmo contrato.",
  "validated_rules": [
    {
      "id": "R01",
      "rule": "NUNCA vender opcao sem checar a curva forward primeiro",
      "reason": "Backwardation forte = mercado em stress = risco de squeeze. Perdi $8K em NG ignorando isso.",
      "severity": "HARD_STOP"
    },
    {
      "id": "R02",
      "rule": "IV Rank < 25% = NAO vender premium. Esperar.",
      "reason": "Premium coletado e muito baixo vs risco. Theta nao compensa gamma risk em IV baixa.",
      "severity": "HARD_STOP"
    },
    {
      "id": "R03",
      "rule": "WASDE day = fechar ou reduzir posicao em graos 24h antes",
      "reason": "WASDE pode mover ZS/ZC 5-8% em minutos. Nao vale o theta de 1 dia extra.",
      "severity": "HARD_STOP"
    },
    {
      "id": "R04",
      "rule": "COT index > 90 OU < 10 = trade with the reversal, nao contra",
      "reason": "Extremos de posicionamento antecipam reversoes em 2-4 semanas. Edge estatistico comprovado.",
      "severity": "STRONG"
    },
    {
      "id": "R05",
      "rule": "Sazonalidade so vale se confirmada por pelo menos 1 outro fator",
      "reason": "Sazonalidade sozinha tem win rate de ~55%. Com COT ou IV confirming, sobe para 70%+.",
      "severity": "STRONG"
    },
    {
      "id": "R06",
      "rule": "Max loss por trade = 2x credito recebido. Stop mecanico.",
      "reason": "Sem stop, um trade ruim pode apagar 5 trades bons. Disciplina > otimismo.",
      "severity": "HARD_STOP"
    },
    {
      "id": "R07",
      "rule": "Nao adicionar a posicao perdedora. Nunca.",
      "reason": "Averaging down em opcoes vendidas aumenta risco exponencialmente. Aprendi com CL em Jan/25.",
      "severity": "HARD_STOP"
    },
    {
      "id": "R08",
      "rule": "Fechar a 50% do max profit. Nao esperar expiracao.",
      "reason": "Ultimos 20% do profit levam 80% do tempo. Capital rotation > max extraction.",
      "severity": "STRONG"
    },
    {
      "id": "R09",
      "rule": "DTE < 21 com profit < 25% = fechar e rolar",
      "reason": "Gamma risk acelera nos ultimos 21 dias. Theta nao compensa o risco de assignment.",
      "severity": "MODERATE"
    },
    {
      "id": "R10",
      "rule": "Skew > +15% = mercado precificando tail risk em puts. Considerar como warning.",
      "reason": "Skew extremo indica smart money comprando protecao. Nao ignorar.",
      "severity": "MODERATE"
    },
    {
      "id": "R11",
      "rule": "Nao operar mais de 3 underlyings correlacionados simultaneamente",
      "reason": "ZS+ZC+ZM sao essencialmente a mesma posicao. Diversificacao real = setores diferentes.",
      "severity": "STRONG"
    },
    {
      "id": "R12",
      "rule": "Sexta-feira pos 14h ET = nao abrir posicao nova. Risco de gap no domingo.",
      "reason": "Weekend risk nao tem theta. Qualquer geopolitica pode abrir gap de 3-5%.",
      "severity": "MODERATE"
    }
  ],
